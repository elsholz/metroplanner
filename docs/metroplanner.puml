@startuml MetroPlanner

title Metro Planner Class Diagram

class MetroPlan {
    + _id
    + planName: String
    + colorTheme: String
    + nodes: [NamedNode]
    + lines: [Line]
    + markerClasses: [MarkerClass]
    + labelClasses: [MarkerClass]
    + labels: [Label]
}

class NamedNode {
    + id: String 
    + location: Point
    + label: Label
    + marker: Marker
}

class Point {
    + x: Number
    + y: Number
}

class Marker {
    + class: MarkerClass
    + width: Number
    + height: Number
    + sizeFactor: Number
}

class MarkerClass {
    + name: String
    + backgroundColor: String
    + color: String
    + borderWidth: String
    + boxShadow: String
    + borderStyle: String
    + borderColor: String
}

MarkerClass -- Marker

class Label {
    + labelClass: LabelClass
    + text: String
    + anchor: String
}

class LabelClass {
    + name: String
    + fontSize: Number
    + height: Number 
    + lineHeight: Number
    + fontWeight: String
    + top: String
    + left: String
}
note top of LabelClass: Predefined Label Classes
note right of MarkerClass: Predefined Marker Classes
note bottom of ColorTheme: Predefined Color Themes

LabelClass - Label

Marker -- NamedNode
Label -up- NamedNode
Label -* MetroPlan

class Line {
    + symbol: String
    + name: String
    + color: String
    + width: Number
    + connections:\n[ConnectedNodes]
}

ConnectedNodes -o Line

class ConnectedNodes {
    + nodes: [Point | NamedNode]
}

ConnectedNodes o-- NamedNode
Point --o ConnectedNodes

class ColorTheme {
    + _id: ObjectID
    + name: String
    + background: String
    + foreground: String
    + lineColors: [String]
    + deepWater: String
    + shallowWater: String
    + border: String
}

MetroPlan - ColorTheme
NamedNode -* MetroPlan
Line --* MetroPlan

@enduml